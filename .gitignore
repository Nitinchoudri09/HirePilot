# ─────────────────────────────────────────────────────────────────────────────
# HirePilot — .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Secrets (NEVER commit these) ──────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
*.egg-info/
dist/
build/
*.egg
.eggs/

# ── Virtual Environments ───────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Django ────────────────────────────────────────────────────────────────────
db.sqlite3
*.sqlite3
staticfiles/*
!staticfiles/.gitkeep
media/
*.log

# ── IDEs / Editors ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
# ── Node / Next.js ────────────────────────────────────────────────────────────
node_modules/
.next/
out/
refera/frontend/.env.local
refera/backend/.env
refera/backend/uploads/
refera/backend/venv/
