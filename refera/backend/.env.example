# Refera Backend Environment Variables
DATABASE_URL=postgresql://refera:refera@localhost:5432/refera_db
SECRET_KEY=your-super-secret-key-change-in-production
FRONTEND_URL=http://localhost:3000

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# OpenAI (optional — falls back to smart templates)
OPENAI_API_KEY=

# AWS S3 (optional — falls back to local storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1

# Razorpay (optional — demo mode without keys)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
